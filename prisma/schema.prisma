generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TipoGasto {
  TARJETA
  PRESTAMO
  FIJO
}

model CategoriaGasto {
  idCategoria String  @id @default(cuid())
  nombre      String
  icon        String  @default("help-circle")
  gastos      Gasto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gasto {
  idGasto           String         @id @default(cuid())
  concepto          String
  idCategoria       String
  categoria         CategoriaGasto @relation(fields: [idCategoria], references: [idCategoria])
  finalizado        Boolean        @default(false)
  fechaFinalizacion DateTime?
  tipoGasto         TipoGasto
  montoDeuda        Int
  montoAbonado      Int            @default(0)
  montoTotal        Int            @default(0)
  cuotasAbonadas    Int            @default(0)
  totalCuotas       Int            @default(0)
  diaPago           Int
  idOwner           String
  pagos             Pago[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pago {
  idPago      String   @id @default(cuid())
  idGasto     String?
  gasto       Gasto?   @relation(fields: [idGasto], references: [idGasto])
  descripcion String
  monto       Int
  fechaPago   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
